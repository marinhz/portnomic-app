# ==============================================================================
# Portnomic - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values for your environment.

# -- General -------------------------------------------------------------------
ENVIRONMENT=development

# -- Database ------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://shipflow:shipflow_dev@localhost:5432/shipflow
DATABASE_URL_SYNC=postgresql://shipflow:shipflow_dev@localhost:5432/shipflow

# -- Redis ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -- Authentication / JWT ------------------------------------------------------
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_MINUTES=10080

# -- Platform Admin (tenant management) -----------------------------------------
# Comma-separated emails; users with these emails can create/manage companies
# Include admin@portnomic.com for super-admin screenshots (seed user)
PLATFORM_ADMIN_EMAILS=admin@portnomic.ai,admin@portnomic.com

# -- MFA -----------------------------------------------------------------------
MFA_ENCRYPTION_KEY=generate-with-python-cryptography-fernet-generate-key

# -- CORS / Security -----------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_AUTH_PER_MINUTE=20

# -- LLM / AI Parsing ---------------------------------------------------------
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
# Single attempt on ingest (no retries); manual retry from UI uses normal retries
LLM_PARSE_SINGLE_ATTEMPT_ON_INGEST=true
# Only sync vessel-related emails; set false to sync all inbox
LLM_VESSEL_ONLY_SYNC=true

# -- IMAP Email Ingest ---------------------------------------------------------
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_USE_SSL=true
IMAP_POLL_INTERVAL_SECONDS=60
IMAP_DEFAULT_TENANT_ID=

# -- Webhook -------------------------------------------------------------------
WEBHOOK_INBOUND_SECRET=

# -- myPOS Billing (Task 8.6) --------------------------------------------------
