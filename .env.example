API_PUBLIC_BASE_URL=https://localhost/checkout-test

# -- Object Storage (local or S3-compatible) -----------------------------------
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_ENDPOINT_URL=

# -- SMTP / Outbound Email -----------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=noreply@portnomic.ai
SMTP_FROM_NAME=Portnomic

