# ShipFlow AI — Terraform Variables
# Copy this file to terraform.tfvars and fill in your values.
# Alternatively, use an environment-specific file:
#   terraform plan -var-file=environments/dev.tfvars

# Required: deployment target
environment = "dev"       # dev | staging | production
aws_region  = "us-east-1"

# Networking
vpc_cidr = "10.0.0.0/16"

# Database (PostgreSQL 16)
db_instance_class    = "db.t3.medium"  # db.t3.micro for dev, db.r6g.large for prod
db_allocated_storage = 50              # GB

# Cache (Redis 7)
redis_node_type = "cache.t3.medium"    # cache.t3.micro for dev, cache.r6g.large for prod

# EKS Cluster
eks_node_instance_type = "t3.medium"
eks_node_min_size      = 1
eks_node_max_size      = 5
eks_node_desired_size  = 2

# DNS — your registered domain
domain_name = "shipflow.io"

# Safety — set to false only in dev
enable_deletion_protection = true
