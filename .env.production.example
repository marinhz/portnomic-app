# ==============================================================================
# Portnomic - Production Environment (app.portnomic.com)
# ==============================================================================
# Copy to .env on your VPS, then fill in the placeholders marked with YOUR_*
# ==============================================================================
#
# Generate secrets:
#   POSTGRES_PASSWORD:  openssl rand -base64 32
#   JWT_SECRET:         openssl rand -base64 32
#   MFA_ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   OAUTH_STATE_ENCRYPTION_KEY: same as MFA_ENCRYPTION_KEY or another Fernet key
# ==============================================================================

ENVIRONMENT=production

# -- Database (use postgres/redis hostnames - Docker service names) ------------
POSTGRES_DB=shipflow
POSTGRES_USER=shipflow
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD

DATABASE_URL=postgresql+asyncpg://shipflow:YOUR_POSTGRES_PASSWORD@postgres:5432/shipflow?ssl=disable
DATABASE_URL_SYNC=postgresql://shipflow:YOUR_POSTGRES_PASSWORD@postgres:5432/shipflow?sslmode=disable

REDIS_URL=redis://redis:6379/0

# -- Authentication / JWT ------------------------------------------------------
JWT_SECRET=YOUR_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_MINUTES=10080

# -- MFA -----------------------------------------------------------------------
MFA_ENCRYPTION_KEY=YOUR_MFA_FERNET_KEY

# -- Platform Admin -----------------------------------------------------------
PLATFORM_ADMIN_EMAILS=admin@portnomic.com

# -- CORS / Security ----------------------------------------------------------
CORS_ORIGINS=["https://app.portnomic.com"]
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_AUTH_PER_MINUTE=20

# -- LLM / AI Parsing (OpenAI, Groq, OpenRouter, etc.) ------------------------
LLM_API_URL=https://api.groq.com/openai/v1
LLM_API_KEY=YOUR_LLM_API_KEY
LLM_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_PARSE_SINGLE_ATTEMPT_ON_INGEST=true
LLM_VESSEL_ONLY_SYNC=true

# -- IMAP (optional) ----------------------------------------------------------
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_USE_SSL=true
IMAP_POLL_INTERVAL_SECONDS=60
IMAP_DEFAULT_TENANT_ID=

# -- OAuth 2.0 – Google (Gmail) -----------------------------------------------
# Add redirect URI in Google Console: https://app.portnomic.com/api/v1/integrations/email/callback
GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# -- OAuth 2.0 – Microsoft (Outlook) ------------------------------------------
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common

# -- OAuth shared (must match app.portnomic.com) -------------------------------
OAUTH_REDIRECT_BASE_URL=https://app.portnomic.com
OAUTH_FRONTEND_SUCCESS_URL=https://app.portnomic.com/settings/integrations
OAUTH_STATE_ENCRYPTION_KEY=YOUR_OAUTH_STATE_FERNET_KEY

# -- Webhook -------------------------------------------------------------------
WEBHOOK_INBOUND_SECRET=YOUR_WEBHOOK_SECRET

# -- myPOS Billing -------------------------------------------------------------
# Sandbox: checkout-test / Production: checkout
MYPOS_SID=000000000000010
MYPOS_WALLET_NUMBER=61938166610
MYPOS_KEY_INDEX=1
MYPOS_PRIVATE_KEY="YOUR_MYPOS_PRIVATE_KEY_PEM"
MYPOS_PUBLIC_CERT="YOUR_MYPOS_PUBLIC_CERT_PEM"
MYPOS_BASE_URL=https://www.mypos.com/vmp/checkout-test
MYPOS_CURRENCY=EUR
MYPOS_AMOUNT_STARTER_MONTHLY=9.99
MYPOS_AMOUNT_PROFESSIONAL_MONTHLY=29.99
API_PUBLIC_BASE_URL=https://app.portnomic.com

# -- Object Storage ------------------------------------------------------------
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage

# -- SMTP / Outbound Email -----------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDRESS=noreply@portnomic.com
SMTP_FROM_NAME=Portnomic
